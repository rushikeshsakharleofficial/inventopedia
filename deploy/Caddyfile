inventopedia.example.com {
    encode gzip zstd

    handle /api/* {
        reverse_proxy backend:8080
    }

    handle /health {
        reverse_proxy backend:8080
    }

    handle /ready {
        reverse_proxy backend:8080
    }

    handle {
        root * /srv/inventopedia/frontend
        try_files {path} /index.html
        file_server
    }
}
